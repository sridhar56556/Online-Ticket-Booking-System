<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Ticketap</display-name>

    <!-- Welcome page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.ticketap.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Signup -->
    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.ticketap.servlets.SignupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <!-- Search Bus -->
    <servlet>
        <servlet-name>SearchBusServlet</servlet-name>
        <servlet-class>com.ticketap.servlets.SearchBusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchBusServlet</servlet-name>
        <url-pattern>/searchBus</url-pattern>
    </servlet-mapping>

    <!-- Booking -->
    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>com.ticketap.servlets.BookingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/bookTicket</url-pattern>
    </servlet-mapping>

</web-app>